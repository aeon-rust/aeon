{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Events Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(aeon_events_received_total[1m])",
          "legendFormat": "Received",
          "refId": "A"
        },
        {
          "expr": "rate(aeon_events_processed_total[1m])",
          "legendFormat": "Processed",
          "refId": "B"
        },
        {
          "expr": "rate(aeon_outputs_sent_total[1m])",
          "legendFormat": "Sent",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Event Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(aeon_e2e_latency_seconds_bucket[1m]))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(aeon_e2e_latency_seconds_bucket[1m]))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(aeon_e2e_latency_seconds_bucket[1m]))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      }
    },
    {
      "title": "Per-Partition Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(aeon_partition_received_total[1m])",
          "legendFormat": "Partition {{partition}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Buffer Utilization",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "aeon_source_buffer_pct",
          "legendFormat": "Source Buffer",
          "refId": "A"
        },
        {
          "expr": "aeon_sink_buffer_pct",
          "legendFormat": "Sink Buffer",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "Batch Size",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "aeon_batch_size",
          "legendFormat": "Current",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Fault Tolerance",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 12 },
      "targets": [
        {
          "expr": "aeon_dlq_total",
          "legendFormat": "DLQ Events",
          "refId": "A"
        },
        {
          "expr": "aeon_retries_total",
          "legendFormat": "Retries",
          "refId": "B"
        },
        {
          "expr": "aeon_circuit_breaker_trips_total",
          "legendFormat": "CB Trips",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Circuit Breaker State",
      "type": "state-timeline",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "aeon_circuit_breaker_state",
          "legendFormat": "State",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Closed", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "Open", "color": "red" } } },
            { "type": "value", "options": { "2": { "text": "Half-Open", "color": "yellow" } } }
          ]
        }
      }
    },
    {
      "title": "Stage Latency Breakdown",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(aeon_source_latency_seconds_bucket[1m]))",
          "legendFormat": "Source P95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(aeon_processor_latency_seconds_bucket[1m]))",
          "legendFormat": "Processor P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, rate(aeon_sink_latency_seconds_bucket[1m]))",
          "legendFormat": "Sink P95",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["aeon"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Aeon Pipeline",
  "uid": "aeon-pipeline",
  "version": 1
}
