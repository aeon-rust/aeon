# Aeon — Environment Configuration
# Copy to .env and fill in values before running.
#
# These variables can be set via a .env file, shell export, or injected
# through CI/CD pipelines (GitHub Actions secrets, Kubernetes ConfigMaps, etc.).
#
# PRODUCTION: All *_PASSWORD and AEON_API_TOKEN variables are REQUIRED.
# DEVELOPMENT: Only POSTGRES_PASSWORD, MYSQL_ROOT_PASSWORD, MYSQL_PASSWORD,
#              RABBITMQ_PASSWORD, and GRAFANA_ADMIN_PASSWORD are required
#              (docker-compose.yml uses :? syntax to enforce these).

# ─── Aeon API ──────────────────────────────────────────────────────────
# Bearer token for REST API authentication.
# REQUIRED in production. Unset = auth disabled (dev mode only).
# Min 32 characters, cryptographically random recommended.
# AEON_API_TOKEN=your-secret-token-here

# REST API address (CLI reads this to know where the engine is).
# AEON_API_URL=http://localhost:4471

# ─── Aeon Engine ───────────────────────────────────────────────────────
# Checkpoint WAL directory. Defaults to OS temp dir in dev.
# REQUIRED in production — must be a persistent volume.
# AEON_CHECKPOINT_DIR=/var/lib/aeon/checkpoints

# Log format: "json" for production (Loki-compatible), "pretty" for dev.
# AEON_LOG_FORMAT=json

# Rust log level filter. Default: info. Options: error, warn, info, debug, trace.
# RUST_LOG=info

# ─── Aeon Cluster ─────────────────────────────────────────────────────
# Unique node ID within the cluster. REQUIRED for multi-node.
# AEON_CLUSTER_NODE_ID=node-1

# QUIC inter-node transport bind address. Default: 0.0.0.0:4470
# Only listens in multi-node mode.
# AEON_CLUSTER_BIND=0.0.0.0:4470

# HTTP management plane bind address. Default: 0.0.0.0:4471
# AEON_HTTP_BIND=0.0.0.0:4471

# Data directory for persistent state (WAL, Raft log, processor registry).
# AEON_INSTANCE_DATA_DIR=/var/lib/aeon/data

# Log directory for structured log files.
# AEON_INSTANCE_LOG_DIR=/var/log/aeon

# ─── OpenTelemetry (vendor-neutral observability) ──────────────────────
# Set OTEL_EXPORTER_OTLP_ENDPOINT to enable OTLP trace/log/metric export.
# Aeon emits OTLP once; the OTel Collector routes to your chosen backend(s):
#   SigNoz, Grafana Tempo, Jaeger, Elastic APM, OpenObserve, Datadog, etc.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_SERVICE_NAME=aeon

# ─── Redpanda / Kafka ─────────────────────────────────────────────────
# REDPANDA_VERSION=v24.2.12
# REDPANDA_SMP=4
# REDPANDA_MEMORY=4G
# REDPANDA_LOG_LEVEL=warn

# ─── Benchmarking ─────────────────────────────────────────────────────
# These control benchmark binaries (cargo bench, aeon-producer, aeon-pipeline).
# All have sensible defaults; override only when tuning.
# AEON_BENCH_BROKERS=localhost:19092
# AEON_BENCH_NUM_PARTITIONS=16
# AEON_BENCH_EVENT_COUNT=100000
# AEON_BENCH_PAYLOAD_SIZE=256
# AEON_BENCH_BATCH_SIZE=1024
# AEON_BENCH_FLUSH_INTERVAL_MS=1000
# AEON_BENCH_MAX_PENDING=50000
# AEON_BENCH_RUST_WASM=samples/processors/wasm-bins/rust-processor.wasm
# AEON_BENCH_AS_WASM=samples/processors/wasm-bins/assemblyscript-processor.wasm

# ─── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_USER=aeon
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=aeon

# ─── MySQL ─────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change-me-mysql-root
MYSQL_USER=aeon
MYSQL_PASSWORD=change-me-mysql
MYSQL_DB=aeon

# ─── RabbitMQ ──────────────────────────────────────────────────────────
RABBITMQ_USER=aeon
RABBITMQ_PASSWORD=change-me-rabbitmq

# ─── Grafana ───────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana
# Set to "true" only in dev environments. Default: false (auth required).
GRAFANA_ANONYMOUS_ENABLED=false
